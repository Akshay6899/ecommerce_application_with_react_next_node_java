# Postgres (Express service)
DATABASE_URL=postgresql://ecom:ecom@localhost:5432/ecom

# Mongo (Fastify service)
MONGO_URL=mongodb://localhost:27017
MONGO_DB=ecom

# JWT
JWT_SECRET=change_me_super_secret_in_prod

# Service ports
EXPRESS_PORT=4001
FASTIFY_PORT=4002
JAVA_PORT=4003

# Frontend → backend URLs (exposed to browser)
NEXT_PUBLIC_AUTH_URL=http://localhost:4001
NEXT_PUBLIC_CATALOG_URL=http://localhost:4002
NEXT_PUBLIC_PAYMENT_URL=http://localhost:4003
